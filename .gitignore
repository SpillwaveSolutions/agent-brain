# --- Override global ~/.gitignore_global ---
# The user's global excludes file ignores `CLAUDE.md` and `.claude/` wholesale.
# Re-include them so this repo's tracked Claude config wins. Git cannot
# re-include a child of an excluded directory unless the directory itself is
# re-included first, so we negate BOTH `.claude/` (the dir) and `.claude/**`
# (its contents). The runtime/local re-ignores further down still apply because
# the last matching pattern wins.
!CLAUDE.md
!AGENTS.md
!.claude/
!.claude/**
!.opencode/
!e2e-cli/lib/
!e2e-cli/lib/*.sh
.env

# Agent Brain per-project runtime state
# (re-ignored AFTER the broad .claude/** re-include above — last match wins)
.claude/agent-brain/
.claude/doc-serve/
.claude/settings.local.json

# Local tool state
.claude/projects/
.claude/scheduled_tasks.lock
agent-brain-server/.agent-brain/
# Repo-root runtime state created by framework-matrix seeded-server fixtures
/.agent-brain/
framework-matrix/.agent-brain/
# TypeScript framework-matrix (Phase 62) Node deps + build/test artifacts
framework-matrix/ts/node_modules/
framework-matrix/ts/.agent-brain/
